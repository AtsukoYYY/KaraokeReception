@model RoomSearchResultViewModel

@{
    ViewData["Title"] = "空室検索結果";
}

<h1 class="mb-4">空室候補</h1>

<div class="mb-4">
    <p class="mb-1">
        利用人数:
        大人 @Model.SearchCondition.AdultCount 人 /
        学生 @Model.SearchCondition.StudentCount 人 /
        シニア @Model.SearchCondition.SeniorCount 人
    </p>
    <p class="mb-0">
        利用時間:
        @Model.SearchCondition.StartTime.ToString("yyyy/MM/dd HH:mm")
        〜
        @Model.SearchCondition.EndTime.ToString("yyyy/MM/dd HH:mm")
    </p>
    <p class="mb-0">
        利用時間合計:
        @Model.TotalUsageTime
    </p>
</div>

@if (Model.AvailableRooms.Count == 0)
{
    <p>条件に合う空室はありません。</p>
}
else
{
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th>部屋</th>
                <th>定員</th>
                <th>機種</th>
                <th>見込み料金（税込）</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var room in Model.AvailableRooms)
            {
                <tr>
                    <td>
                        <strong>@room.RoomName</strong>
                        <div class="text-muted small">@room.RoomId</div>
                    </td>
                    <td>@room.Capacity</td>
                    <td>@room.MachineType</td>
                    <td>@room.EstimatedPriceIncludeTax</td>
                    <td>
                        <form asp-action="Confirm" method="get">
                            <input type="hidden" name="RoomId" value="@room.RoomId" />
                            <input type="hidden" name="AdultCount" value="@Model.SearchCondition.AdultCount" />
                            <input type="hidden" name="StudentCount" value="@Model.SearchCondition.StudentCount" />
                            <input type="hidden" name="SeniorCount" value="@Model.SearchCondition.SeniorCount" />
                            <input type="hidden" name="StartTime" value="@Model.SearchCondition.StartTime.ToString("O")" />
                            <input type="hidden" name="EndTime" value="@Model.SearchCondition.EndTime.ToString("O")" />
                            <button type="submit" class="btn btn-outline-primary btn-sm">
                                この部屋で予約
                            </button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<a asp-action="Index" class="btn btn-secondary">
    条件を変更する
</a>
